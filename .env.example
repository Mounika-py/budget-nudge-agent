# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (optional — app falls back to rule-based nudges without it)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Exotel SMS Credentials (required for real mobile OTP)
# Get these at: https://exotel.com/
EXOTEL_API_KEY=your_exotel_api_key_here
EXOTEL_API_TOKEN=your_exotel_api_token_here
EXOTEL_ACCOUNT_SID=your_exotel_sid_here
EXOTEL_SENDER_ID=your_exotel_sender_id_here
EXOTEL_SUBDOMAIN=api.exotel.com
